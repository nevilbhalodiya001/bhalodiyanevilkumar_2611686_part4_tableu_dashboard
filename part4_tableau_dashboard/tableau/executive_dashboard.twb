      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_1265830127980545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])/SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1265830128119810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales]-[profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1265830128193539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])/COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1265830128373764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag])/COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1265830128496645]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 1 THEN &quot;Same Day (0-1d)&quot; ELSEIF [delivery_days] &lt;= 3 THEN &quot;Fast (2-3d)&quot; ELSEIF [delivery_days] &lt;= 5 THEN &quot;Standard (4-5d)&quot; ELSE &quot;Delayed (6d+)&quot; END' />
      </column>
